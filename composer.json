{
    "name": "webrek/laravel-mongo-permission",
    "description": "Role and permission management for Laravel with a MongoDB backend",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "mongodb",
        "permissions",
        "roles",
        "rbac",
        "acl",
        "authorization",
        "multi-tenant",
        "wildcard"
    ],
    "support": {
        "issues": "https://github.com/webrek/laravel-mongo-permission/issues",
        "source": "https://github.com/webrek/laravel-mongo-permission"
    },
    "require": {
        "php": "^8.1",
        "illuminate/auth": "^10.0|^11.0|^12.0",
        "illuminate/container": "^10.0|^11.0|^12.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/database": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "mongodb/laravel-mongodb": "^4.0|^5.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Webrek\\MongoPermission\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Webrek\\MongoPermission\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webrek\\MongoPermission\\MongoPermissionServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
